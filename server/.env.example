# Copy to .env and fill values
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
PORT=5000

# Frontend URLs (update for production)
FRONTEND_URL_PRIMARY=https://rockyitservices.com
FRONTEND_URL_WWW=https://www.rockyitservices.com

# Optional: app host
HOST=0.0.0.0

# MongoDB Atlas connection
MONGO_URI=your_mongo_connection_string

# JWT Secret
JWT_SECRET=your_secret_key

# Telegram Startup Alert
SEND_TELEGRAM_STARTUP_ALERT=false

# Admin OTP Authentication
ADMIN_USERNAME=admin
